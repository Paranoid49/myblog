# .env.example

# === 必须配置（生产环境） ===

# 随机密钥，长度不少于 32 字符
# 生成方式：python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me

# 运行环境：development / production
# 生产环境会强制校验 SECRET_KEY
ENVIRONMENT=development

# === 可选配置 ===

# 数据库连接（默认 SQLite）
# SQLite:      sqlite:///myblog.db
# PostgreSQL:  postgresql+psycopg://user:pass@localhost:5432/myblog
DATABASE_URL=sqlite:///myblog.db

# 扩展模块（逗号分隔的 Python 模块路径）
EXTENSION_MODULES=
